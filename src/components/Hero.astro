---
import { Image } from 'astro:assets';
import carlosPhoto from '../assets/carlos-zambrana.jpg';
---

<section class="relative overflow-hidden">
  <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-32">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">
      <!-- Photo -->
      <div class="shrink-0">
        <div class="relative">
          <div class="absolute -inset-1 bg-primary-500/20 rounded-full blur-sm"></div>
          <Image
            src={carlosPhoto}
            alt="Carlos Zambrana"
            width={208}
            height={208}
            loading="eager"
            class="relative w-40 h-40 md:w-52 md:h-52 rounded-full object-cover border-4 border-white shadow-lg"
          />
        </div>
      </div>

      <!-- Content -->
      <div class="text-center md:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary-500/10 border border-primary-300 mb-6">
          <span class="w-2 h-2 bg-primary-500 rounded-full animate-pulse"></span>
          <span class="text-sm text-primary-600 font-medium">Available for new projects</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-teal-text mb-4 tracking-tight">
          Carlos Zambrana
        </h1>

        <p class="text-xl md:text-2xl text-primary-500 font-semibold mb-6">
          Full Stack Developer & Consultant
        </p>

        <p class="text-lg text-teal-muted max-w-xl mb-8 leading-relaxed">
          10+ years building scalable web applications, APIs, and cloud infrastructure
          for companies across the US. I turn complex business requirements into
          production-ready software.
        </p>

        <div class="flex flex-wrap justify-center md:justify-start gap-4 mb-8">
          <a
            href="#contact"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary-500 text-white font-medium hover:bg-primary-600 transition-colors"
          >
            Get in Touch
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/carlos-zambrana-resume.pdf"
            download
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-teal-border text-teal-body font-medium hover:border-primary-400 hover:text-primary-600 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume
          </a>
        </div>

        <!-- Quick stats -->
        <div class="flex flex-wrap justify-center md:justify-start gap-8 pt-6 border-t border-teal-border">
          <div>
            <p class="text-2xl font-bold text-teal-text">10+</p>
            <p class="text-sm text-teal-muted">Years Experience</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-teal-text">20+</p>
            <p class="text-sm text-teal-muted">Projects Delivered</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-teal-text">5+</p>
            <p class="text-sm text-teal-muted">Enterprise Clients</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
