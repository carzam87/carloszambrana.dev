---
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Skills', href: '#skills' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-teal-border">
  <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-primary-500 flex items-center justify-center text-white text-xs font-bold">CZ</div>
      <span class="text-base font-semibold text-teal-text tracking-tight">Carlos Zambrana</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-teal-muted hover:text-primary-500 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/carlos-zambrana-resume.pdf"
        download
        class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-lg bg-primary-500 text-white hover:bg-primary-600 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Resume
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-teal-muted transition-transform" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-teal-muted transition-opacity" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-teal-muted transition-transform" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-teal-border bg-white">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-link text-sm font-medium text-teal-muted hover:text-primary-500 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/carlos-zambrana-resume.pdf"
        download
        class="inline-flex items-center gap-2 text-sm font-medium text-primary-500"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download Resume
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    bar1.style.transform = isOpen ? '' : 'rotate(45deg) translate(4px, 4px)';
    bar2.style.opacity = isOpen ? '1' : '0';
    bar3.style.transform = isOpen ? '' : 'rotate(-45deg) translate(4px, -4px)';
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      bar1.style.transform = '';
      bar2.style.opacity = '1';
      bar3.style.transform = '';
    });
  });
</script>
