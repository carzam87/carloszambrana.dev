---
const engagements = [
  {
    client: 'MNA Healthcare',
    role: 'Lead Engineer — Healthcare ERP Platform',
    period: '2021 — Present',
    description: 'Architected and developed a comprehensive ERP system for a US-based healthcare staffing agency. Led the complete modernization of a legacy application into a scalable, enterprise-grade platform handling nurse onboarding, compliance tracking, and payroll processing.',
    highlights: [
      'Rebuilt core platform from legacy jQuery to a modular Laravel + Vue.js architecture',
      'Engineered financial modules for payroll, commissions, and automated invoicing',
      'Built integrations with Zoom, SMS gateways, and WordPress for unified workflows',
      'Developed Node.js automation tools reducing manual data entry by 40%+',
    ],
  },
  {
    client: 'NicaSource',
    role: 'Team Lead — Enterprise Client Projects',
    period: '2020 — 2022',
    description: 'Led development teams delivering software solutions for US-based enterprise clients, including a custom Learning Management System and headless CMS platforms.',
    highlights: [
      'Delivered a full-featured LMS using Django and React for a major US client',
      'Architected a headless CMS with Laravel Nova supporting multiple frontends',
      'Implemented serverless processing with AWS Lambda and SES',
      'Mentored junior developers through code reviews and best-practice workshops',
    ],
  },
  {
    client: 'Numu Digital',
    role: 'Full Stack Developer — Web & Mobile Applications',
    period: '2019 — 2021',
    description: 'Developed cross-platform web and mobile applications for NGO and e-commerce clients, delivering custom solutions with Laravel and the Ionic Framework.',
    highlights: [
      'Built cross-platform mobile and web applications for NGO clients',
      'Developed custom WordPress/WooCommerce plugins for e-commerce platforms',
      'Implemented Stripe payment integrations and third-party API connections',
    ],
  },
];
---

<section id="experience" class="py-20 md:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
      Client Engagements
    </h2>
    <p class="text-gray-500 text-center max-w-2xl mx-auto mb-16">
      A track record of delivering impactful software for clients across industries.
    </p>
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-0 md:left-8 top-0 bottom-0 w-px bg-gray-200 hidden md:block"></div>

      <div class="space-y-12">
        {engagements.map((engagement) => (
          <div class="relative md:pl-20">
            <!-- Timeline dot -->
            <div class="absolute left-0 md:left-[26px] top-1 w-5 h-5 rounded-full bg-primary-600 border-4 border-primary-100 hidden md:block"></div>

            <div class="p-6 md:p-8 rounded-xl border border-gray-100 hover:shadow-md transition-shadow">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-3">
                <h3 class="text-xl font-semibold text-gray-900">{engagement.client}</h3>
                <span class="text-sm text-primary-600 font-medium mt-1 md:mt-0">{engagement.period}</span>
              </div>
              <p class="text-sm font-medium text-gray-500 mb-4">{engagement.role}</p>
              <p class="text-gray-600 leading-relaxed mb-4">{engagement.description}</p>
              <ul class="space-y-2">
                {engagement.highlights.map((highlight) => (
                  <li class="flex items-start gap-2 text-sm text-gray-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {highlight}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
