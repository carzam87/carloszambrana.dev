---
const services = [
  {
    title: 'Web Application Development',
    description: 'Full-stack applications with Laravel, Django, Node.js, React, and Vue.js. From MVPs to enterprise platforms tailored to your business.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
  },
  {
    title: 'API Design & Integration',
    description: 'RESTful API architecture, third-party integrations, and payment gateway implementations. Connecting systems for seamless workflows.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
  },
  {
    title: 'Cloud & DevOps',
    description: 'AWS infrastructure, Docker containerization, and CI/CD pipelines. Scalable deployments that grow with your business.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" /></svg>`,
  },
  {
    title: 'Technical Consulting',
    description: 'Architecture reviews, code audits, and technical strategy. Helping teams make the right decisions and ship with confidence.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5" /></svg>`,
  },
];
---

<section id="services" class="py-20 md:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mb-16">
      <p class="text-sm font-semibold text-primary-600 uppercase tracking-wider mb-3">Services</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        What I Can Do For You
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        End-to-end software development and consulting for businesses
        that need reliable, scalable technology solutions.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((service) => (
        <div class="group relative p-8 rounded-2xl border border-gray-100 bg-white hover:bg-gray-50 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="shrink-0 w-12 h-12 rounded-xl bg-primary-50 text-primary-600 flex items-center justify-center group-hover:bg-primary-600 group-hover:text-white transition-colors duration-300" set:html={service.icon} />
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">{service.title}</h3>
              <p class="text-gray-500 leading-relaxed text-[15px]">{service.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
