---
const services = [
  {
    title: 'Web Application Development',
    description: 'Full-stack applications built with Laravel, Django, Node.js, React, and Vue.js. From MVPs to enterprise-scale platforms tailored to your business needs.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
  },
  {
    title: 'API Design & Integration',
    description: 'RESTful API architecture, third-party service integrations, and payment gateway implementations. Connecting your systems for seamless workflows.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
  },
  {
    title: 'Cloud & DevOps',
    description: 'AWS infrastructure setup, Docker containerization, and CI/CD pipeline automation. Scalable, reliable deployments that grow with your business.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" /></svg>`,
  },
  {
    title: 'Technical Consulting',
    description: 'Architecture reviews, code audits, and technical strategy. I help teams make the right technology decisions and improve development workflows.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5" /></svg>`,
  },
];
---

<section id="services" class="py-20 md:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
      What I Do
    </h2>
    <p class="text-gray-500 text-center max-w-2xl mx-auto mb-16">
      I provide end-to-end software development services, helping businesses
      build and scale their digital products.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map((service) => (
        <div class="p-8 rounded-xl border border-gray-100 hover:border-primary-100 hover:shadow-lg transition-all group">
          <div class="text-primary-600 mb-4" set:html={service.icon} />
          <h3 class="text-xl font-semibold text-gray-900 mb-3">{service.title}</h3>
          <p class="text-gray-500 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
